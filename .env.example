# ============================================================
# MANG — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# Supabase — Récupérez ces valeurs dans Settings > API de votre projet Supabase
VITE_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=VOTRE_ANON_KEY

# FedaPay — Pour les paiements Mobile Money (Bénin)
# https://fedapay.com
VITE_FEDAPAY_PUBLIC_KEY=pk_sandbox_VOTRE_CLE_TEST
VITE_FEDAPAY_ENV=sandbox   # Changer en "live" pour la production

# URL de l'application
VITE_APP_URL=http://localhost:5173
